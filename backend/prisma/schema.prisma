generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  fullName         String
  role             String   // "student" or "supervisor"
  department       String
  groupName        String?
  phone            String?
  studyLevel       String?
  interests        String?
  bio              String?
  avatar           String?
  refreshTokenHash String?
  createdAt        DateTime @default(now())

  // Relations
  supervisorProfile Supervisor?
  studentRequests   Request[]   @relation("StudentRequests")
}

model Supervisor {
  id              String   @id @default(uuid())
  userId          String   @unique
  email           String?
  phone           String?
  name            String
  title           String
  department      String
  bio             String
  capacity        Int      @default(5)
  currentStudents Int      @default(0)
  avatar          String
  areas           String[] // Array of strings is supported in PostgreSQL
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topics          Topic[]
  requests        Request[]
}

model Topic {
  id           String     @id @default(uuid())
  supervisorId String
  title        String
  area         String
  description  String
  createdAt    DateTime   @default(now())

  // Relations
  supervisor   Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
}

model Request {
  id            String     @id @default(uuid())
  studentUserId String
  studentEmail  String
  studentName   String
  supervisorId  String
  message       String
  status        String     @default("pending") // pending, accepted, rejected
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  student       User       @relation("StudentRequests", fields: [studentUserId], references: [id], onDelete: Cascade)
  supervisor    Supervisor @relation(fields: [supervisorId], references: [id], onDelete: Cascade)
}
